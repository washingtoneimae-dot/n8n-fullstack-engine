{
  "name": "Todo App Demo",
  "nodes": [
    {
      "id": "node-webhook-001",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [0, 300],
      "parameters": {
        "path": "todo-app",
        "options": {}
      }
    },
    {
      "id": "node-router-001",
      "name": "App Router",
      "type": "CUSTOM.appRouterNode",
      "typeVersion": 1,
      "position": [250, 300],
      "parameters": {
        "routes": {
          "route": [
            {
              "path": "/",
              "pageTitle": "Home",
              "layout": "default",
              "authRequired": false
            },
            {
              "path": "/todos",
              "pageTitle": "Todo List",
              "layout": "default",
              "authRequired": false
            },
            {
              "path": "/todos/new",
              "pageTitle": "New Todo",
              "layout": "default",
              "authRequired": false
            }
          ]
        },
        "defaultRoute": "/"
      }
    },
    {
      "id": "node-table-001",
      "name": "Create Todos Table",
      "type": "CUSTOM.dataTableNode",
      "typeVersion": 1,
      "position": [500, 200],
      "parameters": {
        "operation": "createTable",
        "tableName": "todos",
        "columns": {
          "column": [
            {
              "name": "id",
              "type": "INTEGER",
              "required": true
            },
            {
              "name": "title",
              "type": "TEXT",
              "required": true
            },
            {
              "name": "description",
              "type": "TEXT",
              "required": false
            },
            {
              "name": "completed",
              "type": "INTEGER",
              "required": false
            }
          ]
        }
      }
    },
    {
      "id": "node-table-002",
      "name": "Fetch Todos",
      "type": "CUSTOM.dataTableNode",
      "typeVersion": 1,
      "position": [500, 400],
      "parameters": {
        "operation": "select",
        "tableName": "todos",
        "whereClause": ""
      }
    },
    {
      "id": "node-page-001",
      "name": "Render Home",
      "type": "CUSTOM.pageNode",
      "typeVersion": 1,
      "position": [750, 200],
      "parameters": {
        "pageTitle": "Todo App",
        "layout": "default",
        "showNav": true
      }
    },
    {
      "id": "node-page-002",
      "name": "Render Todos",
      "type": "CUSTOM.pageNode",
      "typeVersion": 1,
      "position": [750, 400],
      "parameters": {
        "pageTitle": "Todo List",
        "layout": "default",
        "showNav": true
      }
    },
    {
      "id": "node-form-001",
      "name": "Add Todo Form",
      "type": "CUSTOM.formNode",
      "typeVersion": 1,
      "position": [500, 600],
      "parameters": {
        "formFields": {
          "fields": [
            {
              "label": "Title",
              "name": "title",
              "type": "text",
              "required": true,
              "placeholder": "What needs to be done?"
            },
            {
              "label": "Description",
              "name": "description",
              "type": "textarea",
              "required": false,
              "placeholder": "Optional description"
            }
          ]
        },
        "submitText": "Add Todo",
        "successMessage": "Todo added successfully!",
        "formAction": ""
      }
    },
    {
      "id": "node-table-003",
      "name": "Insert Todo",
      "type": "CUSTOM.dataTableNode",
      "typeVersion": 1,
      "position": [750, 600],
      "parameters": {
        "operation": "insert",
        "tableName": "todos",
        "data": ""
      }
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          { "node": "App Router", "type": "main", "index": 0 }
        ]
      ]
    },
    "App Router": {
      "main": [
        [
          { "node": "Create Todos Table", "type": "main", "index": 0 },
          { "node": "Fetch Todos", "type": "main", "index": 0 },
          { "node": "Add Todo Form", "type": "main", "index": 0 }
        ]
      ]
    },
    "Create Todos Table": {
      "main": [
        [
          { "node": "Render Home", "type": "main", "index": 0 }
        ]
      ]
    },
    "Fetch Todos": {
      "main": [
        [
          { "node": "Render Todos", "type": "main", "index": 0 }
        ]
      ]
    },
    "Add Todo Form": {
      "main": [
        [
          { "node": "Insert Todo", "type": "main", "index": 0 }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "staticData": null,
  "tags": []
}
